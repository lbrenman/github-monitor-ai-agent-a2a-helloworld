# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Personal Access Token (classic)
# Scopes needed: read:user, public_repo
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Public URL of the slack-notifier-agent Codespace
# Find this in the Ports tab of the notifier Codespace (port 3100, set to Public)
# Example: https://leor-laughing-spoon-abc123-3100.app.github.dev
NOTIFIER_URL=https://YOUR-CODESPACE-NAME-3100.app.github.dev

# ── Optional ──────────────────────────────────────────────────────────────────

# GitHub username to monitor (default: lbrenman)
# GITHUB_USER=lbrenman

# Poll interval in milliseconds (default: 60000)
# POLL_INTERVAL_MS=60000

# Claude model
# MODEL=claude-opus-4-5-20251101
